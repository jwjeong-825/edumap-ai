<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>EduMap AI</title>
</head>
<body>

    <h1>🎓 EduMap AI</h1>

    <input type="text" id="keyword" placeholder="전공 키워드 입력">
    <select id="searchType">
    <option value="major">학과 키워드</option>
    <option value="university">학교명</option>
    <option value="region">지역</option>
</select>

<input type="text" id="keyword" placeholder="검색어 입력"><select id="searchType">
    <option value="major">학과 키워드</option>
    <option value="university">학교명</option>
    <option value="region">지역</option>
</select>

<input type="text" id="keyword" placeholder="검색어 입력">
    <button onclick="searchMajor()">검색</button>

    <div id="results"></div>

    <script>
        async function searchMajor() {

            const keyword = document.getElementById("keyword").value;

            const response = await fetch(
                `/recommend?keyword=${keyword}`
            );

            const data = await response.json();

            const resultsDiv = document.getElementById("results");

            resultsDiv.innerHTML = "";

            data.results.forEach(item => {

                resultsDiv.innerHTML += `
                    <hr>
                    <h3>${item.학교명}</h3>
                    <p>학과명: ${item.학과명}</p>
                    <p>지역: ${item.대학소재지}</p>
                    <p>계열: ${item.표준중계열}</p>
                `;
            });
        }
    </script>

</body>
</html>
